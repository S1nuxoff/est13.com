# ---------------------------
# Database (recommended: Postgres)
# ---------------------------
POSTGRES_DB=nardo
POSTGRES_USER=nardo
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://nardo:change_me@postgres:5432/nardo

# ---------------------------
# Telegram
# ---------------------------
BOT_TOKEN=put_your_bot_token_here

# ---------------------------
# Admin API auth
# ---------------------------
ADMIN_API_TOKEN=change_me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ---------------------------
# WebApp (Mini App) URL (public https)
# ---------------------------
WEBAPP_URL=https://miniapp.example.com/
VITE_ADMIN_API_URL=https://api.example.com

# ---------------------------
# App settings
# ---------------------------
APP_ENV=prod
LOG_LEVEL=INFO
MEDIA_DIR=/app/data/media
WEBAPP_ALLOW_ANON=false
ADMIN_TG_IDS=
